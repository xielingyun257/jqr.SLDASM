<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================================
  jqr 双机械臂人形上半身机器人 URDF 描述
  ============================================================================
  原始模型：SolidWorks 装配体 jqr.SLDASM，通过 SW2URDF Exporter v1.6.0 导出
  ROS2 适配：手动迁移，修正关节限位、添加运动链注释

  运动链结构：
    base_link (大腿/固定基座)
      └── joint_1 [Z旋转, 腰部] ──▶ link_1 (上躯干)
           ├── joint_l_2 [X] ──▶ Link_l_2 (左肩1)
           │    └── joint_l_3 [Y] ──▶ Link_l_3 (左肩2)
           │         └── joint_l_4 [Z] ──▶ Link_l_4 (左肩3)
           │              └── joint_l_5 [X] ──▶ Link_l_5 (左肘1)
           │                   └── joint_l_6 [Z] ──▶ Link_l_6 (左腕1)
           │                        └── joint_l_7 [X] ──▶ Link_l_7 (左手末端)
           └── joint_r_2 [X] ──▶ Link_r_2 (右肩1)
                └── joint_r_3 [Y] ──▶ Link_r_3 (右肩2)
                     └── joint_r_4 [Z] ──▶ Link_r_4 (右肩3)
                          └── joint_r_5 [X] ──▶ Link_r_5 (右肘1)
                               └── joint_r_6 [Z] ──▶ Link_r_6 (右腕1)
                                    └── joint_r_7 [X] ──▶ Link_r_7 (右手末端)

  关节限位：全部 ±π rad (±180°)，力矩 100 N·m，速度 1.0 rad/s

  适用任务：交通指挥手势（停止/直行/左转/右转/减速/靠边停车/变道/待转）

  原 SW 组件对应：
    leg^jqr-1     → base_link  (大腿)
    qugan^jqr-1   → link_1     (躯干)
    l_jian_*      → 左肩关节
    l_zhou_*      → 左肘关节
    zuoshou-1     → 左手
    r_jian_*      → 右肩关节
    r_zhou_*      → 右肘关节
    youshou-1     → 右手
  ============================================================================
-->
<robot
  name="jqr">
  <!-- ============================================================ -->
  <!-- base_link: 大腿 / 固定基座 (对应 SW 组件: leg^jqr-1)          -->
  <!-- 质量: 25.73 kg                                                -->
  <!-- ============================================================ -->
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="-7.28257887112893E-06 0.00313712189482795 -0.510442515287971"
        rpy="0 0 0" />
      <mass
        value="25.7309030479168" />
      <inertia
        ixx="0.131564424573315"
        ixy="9.22312184388478E-06"
        ixz="-1.92259655939609E-07"
        iyy="0.12863710328844"
        iyz="0.000576826622898757"
        izz="0.0431477760395514" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://jqr_description/meshes/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://jqr_description/meshes/base_link.STL" />
      </geometry>
