    name="link_1">
    <inertial>
      <origin
        xyz="-3.66716048354199E-07 0.01733512366571 0.204933038476789"
        rpy="0 0 0" />
      <mass
        value="18.0550443856409" />
      <inertia
        ixx="0.0703445252773168"
