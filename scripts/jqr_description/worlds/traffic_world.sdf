<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="traffic_intersection">
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <light type="directional" name="sun_light">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 15 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 0.5</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 草地 -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision"><geometry><plane><normal>0 0 1</normal><size>80 80</size></plane></geometry></collision>
        <visual name="visual"><geometry><plane><normal>0 0 1</normal><size>80 80</size></plane></geometry>
          <material><ambient>0.2 0.4 0.2 1</ambient><diffuse>0.25 0.45 0.25 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ===== 路口中央方形区域 (10x10m, 防z-fighting) ===== -->
    <model name="intersection_center">
      <static>true</static>
      <link name="surface">
        <pose>0 0 0.03 0 0 0</pose>
        <visual name="visual"><geometry><box><size>10 10 0.06</size></box></geometry>
          <material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material></visual>
        <collision name="collision"><geometry><box><size>10 10 0.06</size></box></geometry></collision>
      </link>
    </model>

    <!-- ===== 北段路 (X+, 10m长, 不重叠) ===== -->
    <model name="road_north">
      <static>true</static>
      <link name="surface">
        <pose>10 0 0.03 0 0 0</pose>
        <visual name="visual"><geometry><box><size>10 8 0.06</size></box></geometry>
          <material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material></visual>
        <collision name="collision"><geometry><box><size>10 8 0.06</size></box></geometry></collision>
      </link>
    </model>

    <!-- ===== 南段路 (X-, 10m长) ===== -->
    <model name="road_south">
      <static>true</static>
      <link name="surface">
        <pose>-10 0 0.03 0 0 0</pose>
        <visual name="visual"><geometry><box><size>10 8 0.06</size></box></geometry>
          <material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material></visual>
        <collision name="collision"><geometry><box><size>10 8 0.06</size></box></geometry></collision>
      </link>
    </model>

    <!-- ===== 东段路 (Y+, 10m长) ===== -->
    <model name="road_east">
      <static>true</static>
      <link name="surface">
        <pose>0 10 0.03 0 0 1.5708</pose>
        <visual name="visual"><geometry><box><size>10 8 0.06</size></box></geometry>
          <material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material></visual>
        <collision name="collision"><geometry><box><size>10 8 0.06</size></box></geometry></collision>
      </link>
    </model>

    <!-- ===== 西段路 (Y-, 10m长) ===== -->
    <model name="road_west">
      <static>true</static>
      <link name="surface">
        <pose>0 -10 0.03 0 0 1.5708</pose>
