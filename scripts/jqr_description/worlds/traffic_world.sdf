    <!-- ===== 交警站台（路口正中央） ===== -->
    <model name="police_platform">
      <static>true</static>
      <pose>0 0 0.06 0 0 0</pose>
      <link name="base">
        <pose>0 0 0.15 0 0 0</pose>
        <visual name="visual"><geometry><cylinder><radius>0.75</radius><length>0.3</length></cylinder></geometry>
          <material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material></visual>
        <collision name="collision"><geometry><cylinder><radius>0.75</radius><length>0.3</length></cylinder></geometry></collision>
      </link>
      <link name="top">
        <pose>0 0 0.45 0 0 0</pose>
        <visual name="visual"><geometry><cylinder><radius>0.5</radius><length>0.3</length></cylinder></geometry>
          <material><ambient>0.1 0.15 0.4 1</ambient><diffuse>0.12 0.18 0.5 1</diffuse></material></visual>
        <collision name="collision"><geometry><cylinder><radius>0.5</radius><length>0.3</length></cylinder></geometry></collision>
      </link>
    </model>

