    <model name="zebra_north">
      <static>true</static>
      <pose>6.5 0 0.065 0 0 0</pose>
      <link name="s1"><pose>0 -2.4 0 0 0 0</pose><visual name="visual"><geometry><box><size>8.0 0.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
      <link name="s2"><pose>0 -1.6 0 0 0 0</pose><visual name="visual"><geometry><box><size>8.0 0.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link>
