      <link name="wheel_rl"><pose>-1.1 0.95 0.28 0 0 0</pose><visual name="v"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual></link>
      <link name="wheel_rr"><pose>-1.1 -0.95 0.28 0 0 0</pose><visual name="v"><geometry><cylinder><radius>0.28</radius><length>0.2</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material></visual></link>
